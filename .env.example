# ============================
# RenewCred CMS — Environment Variables
# ============================
# Copy this file to .env and fill in the values

# ---- Database ----
DATABASE_URL=postgresql://renewcred:renewcred_password@localhost:5432/renewcred_db?schema=public

# ---- Server ----
SERVER_PORT=4000

# ---- JWT ----
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000

# ---- Client (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ---- Admin Seed Credentials ----
SEED_ADMIN_EMAIL=admin@renewcred.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Admin User
