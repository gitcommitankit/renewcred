{
  "name": "renewcred",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "description": "RenewCred CMS - Content Management System for climate standards",
  "scripts": {
    "dev": "dotenv -e .env -- pnpm --parallel --filter server --filter client dev",
    "dev:client": "dotenv -e .env -- pnpm --filter client dev",
    "dev:server": "dotenv -e .env -- pnpm --filter server dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm format && dotenv -e .env -- pnpm --filter server build && dotenv -e .env -- pnpm --filter client build",
    "build:client": "dotenv -e .env -- pnpm --filter client build",
    "build:server": "dotenv -e .env -- pnpm --filter server build",
    "start": "dotenv -e .env -- pnpm --parallel --filter server --filter client start",
    "start:client": "dotenv -e .env -- pnpm --filter client start",
    "start:server": "dotenv -e .env -- pnpm --filter server start",
    "db:migrate": "dotenv -e .env -- pnpm --filter server db:migrate",
    "db:migrate:prod": "dotenv -e .env -- pnpm --filter server db:migrate:prod",
    "db:generate": "dotenv -e .env -- pnpm --filter server db:generate",
    "db:seed": "dotenv -e .env -- pnpm --filter server db:seed",
    "db:studio": "dotenv -e .env -- pnpm --filter server db:studio",
    "db:reset": "dotenv -e .env -- pnpm --filter server db:reset",
    "postinstall": "pnpm --filter server db:generate"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.3.3"
  }
}
